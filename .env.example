# -----------------------------
# Provider routing
# -----------------------------
# Supported:
# - OpenAI-compatible family: openai_compatible, openai, azure_openai, xai,
#   deepseek, groq, mistral, together, fireworks, openrouter,
#   ollama, lmstudio, vllm, llamacpp
# - Native APIs: anthropic, gemini
MODEL_PROVIDER=openai_compatible

# -----------------------------
# Access policy guard
# -----------------------------
# local: default, intended for localhost/self-hosted endpoints
# online: required when endpoint is remote
MODEL_ACCESS_MODE=local
ALLOW_REMOTE_INFERENCE=false

# -----------------------------
# OpenAI-compatible settings
# -----------------------------
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# -----------------------------
# Anthropic native settings
# -----------------------------
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# -----------------------------
# Gemini native settings
# -----------------------------
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_API_KEY=

# -----------------------------
# Shared model controls
# -----------------------------
MODEL_NAME=deepseek-r1:70b
MODEL_TEMPERATURE=0.2
MODEL_TIMEOUT_SECONDS=60

# Runtime paths
DCT_OUTPUT_DIR=outputs
DCT_SQLITE_PATH=outputs/dct_memory.db

# Optional: strict startup health check against model endpoint
DCT_CHECK_MODEL_ON_START=true

# -----------------------------
# Online API examples (uncomment to use)
# -----------------------------
# Example A: OpenAI API (OpenAI-compatible)
# MODEL_PROVIDER=openai
# MODEL_ACCESS_MODE=online
# ALLOW_REMOTE_INFERENCE=true
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# MODEL_NAME=gpt-5-mini

# Example B: Anthropic native API
# MODEL_PROVIDER=anthropic
# MODEL_ACCESS_MODE=online
# ALLOW_REMOTE_INFERENCE=true
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_NAME=claude-sonnet-4-5

# Example C: Gemini native API
# MODEL_PROVIDER=gemini
# MODEL_ACCESS_MODE=online
# ALLOW_REMOTE_INFERENCE=true
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
# GOOGLE_API_KEY=AIza...
# MODEL_NAME=gemini-2.5-pro
